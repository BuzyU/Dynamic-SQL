## 🗄️ Database Structure

### Records Collection

```javascript
{
  id: "auto-generated",
  userId: "user123",
  systemId: "system456",
  categoryId: "category789",
  title: "PAND Medication",
  description: "Pain relief medication for moderate to severe pain",
  status: "published", // draft | published | archived
  customFields: [
    {
      id: "field_1234567890",
      label: "Manufacturer Name",
      type: "text",
      value: "QQQ3 Pharma",
      required: false,
      order: 0
    },
    {
      id: "field_1234567891",
      label: "Batch Number",
      type: "text",
      value: "B12345",
      required: true,
      order: 1
    },
    {
      id: "field_1234567892",
      label: "Expiry Date",
      type: "date",
      value: "2025-12-31",
      required: true,
      order: 2
    }
  ],
  tags: ["medical", "medication"],
  createdAt: Timestamp,
  updatedAt: Timestamp,
  archived: false
}
```

### Relations Collection

```javascript
{
  id: "auto-generated",
  userId: "user123",
  systemId: "system456",
  sourceRecordId: "record_abc",
  targetRecordId: "record_xyz",
  relationType: "manufactured_by",
  description: "Primary manufacturer for this medication",
  createdAt: Timestamp
}
```

### Relation Types Collection (Optional)

```javascript
{
  id: "auto-generated",
  userId: "user123",
  systemId: "system456",
  name: "manufactured_by",
  displayName: "Manufactured By",
  description: "Links product to its manufacturer",
  icon: "🏭",
  color: "#3B82F6",
  bidirectional: true,
  inverseLabel: "Manufactures"
}
```

